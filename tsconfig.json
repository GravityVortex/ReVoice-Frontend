{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/.source": [
        "./.source.next/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next.config.mjs",
    ".next/dev/types/**/*.ts",
    ".next.codex/types/**/*.ts",
    ".next.build/types/**/*.ts",
    ".next.build/dev/types/**/*.ts",
    ".next.codex/dev/types/**/*.ts",
    ".next.devtmp/types/**/*.ts",
    ".next.devtmp/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next.build",
    ".next.codex/dev",
    "out",
    "dist"
  ]
}
